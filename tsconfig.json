{
  "extends": "@zakodium/tsconfig",
  "compilerOptions": {
    // Disabled on purpose: this is numeric, index-heavy code where every
    // access is provably in-bounds, and `noUncheckedIndexedAccess` would force
    // non-null assertions throughout the hot loops.
    "noUncheckedIndexedAccess": false,
    "outDir": "lib",
    "types": ["node"]
  },
  "include": ["src", "vite*.ts"]
}
